# TrueTraffic — environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Collector ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./truetraffic.db
# Comma-separated list of allowed CORS origins (no wildcards in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# Optional: Sentry DSN for error tracking (leave blank to disable)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Checker ──────────────────────────────────────────────────────────────────
# Path override for ai-agents.json (default: data/ai-agents.json relative to repo root)
# AGENTS_PATH=/app/data/ai-agents.json

# ── Phase 4: Policy manager / Crawler Watch ──────────────────────────────────
# Secret header value for POST /crawlerwatch/sync (leave blank to disable auth)
# SYNC_SECRET=change-me-before-deploying

# Public base URL of the collector (used in unsubscribe links)
BASE_URL=http://localhost:8001

# Resend API key for Crawler Watch email alerts (leave blank to log-only mode)
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# Sender address for outgoing emails
# EMAIL_FROM=TrueTraffic <noreply@truetraffic.dev>

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL of the deployed collector API (used at build time)
VITE_COLLECTOR_URL=http://localhost:8001
