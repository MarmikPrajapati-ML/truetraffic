# TrueTraffic — environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Collector ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./truetraffic.db
# Comma-separated list of allowed CORS origins (no wildcards in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# Optional: Sentry DSN for error tracking (leave blank to disable)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Checker ──────────────────────────────────────────────────────────────────
# Path override for ai-agents.json (default: data/ai-agents.json relative to repo root)
# AGENTS_PATH=/app/data/ai-agents.json

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL of the deployed collector API (used at build time)
VITE_COLLECTOR_URL=http://localhost:8001
